  align-items: center;
}

.nav-logo-img {
  height: 60px;
  width: auto;
  object-fit: contain;
}

/* Class mới: Định vị Text nằm dính bên PHẢI */
.nav-right-text {
  position: absolute;      /* Định vị tuyệt đối */
  right: 30px;             /* Cách lề phải 30px */
  
