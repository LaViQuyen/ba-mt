  .reading-left-pane { overflow-y: auto; }

  /* --- 3. CẤU HÌNH PHẦN WRITING (VIẾT) --- */
  .w-left-pane {
    width: 100% !important;
    height: 40vh !important; /* Đề bài chiếm 40% */
    border-right: none !important;
    border-bottom: 4px solid #e0e0e0;
    padding: 15px !important;
    overflow-y: auto;
  }
  .w-right-pane {
    width: 100% !important;
    height: 50vh !important; /* Chỗ viết chiếm 50% (rộng hơn tí để bàn phím ảo ko che hết) */
    padding: 15px !important;
  }

  /* --- 4. FIX LỖI HEADER BỊ ĐÈ NÚT (QUAN TRỌNG) --- */
  .test-header {
    display: flex !important;
    justify-content: space-between !important; /* Đẩy 2 bên ra xa */
    align-items: center !important;
    padding: 0 10px !important;
    height: 60px !important;
  }

  /* Ẩn Logo để lấy chỗ cho Đồng hồ */
  .header-left { display: none !important; }

  /* Đưa Đồng hồ sang trái (Thay vì nằm giữa) */
  .header-center {
    position: static !important;
    transform: none !important;
  }
  .timer-box {
    font-size: 1rem !important;
    padding: 5px 10px !important;
    background: #f0f8ff;
    border: 1px solid #cce5ff;
    white-space: nowrap;
  }

  /* Nhóm nút bên phải */
  .header-right {
    display: flex !important;
    gap: 8px !important;
    align-items: center;
  }

  /* Thu gọn nút AI Grade (Ẩn chữ, chỉ hiện Icon đũa thần) */
  .btn-ai-header {
    padding: 8px !important;
    min-width: 36px !important;
    justify-content: center !important;
  }
  .btn-ai-header span { display: none !important; } /* Ẩn chữ */
  .btn-ai-header i { margin: 0 !important; font-size: 1.2rem !important; }

  /* Thu gọn nút Nộp bài */
  .submit-btn {
    padding: 8px 12px !important;
    font-size: 0.85rem !important;
  }

  /* --- 5. THANH CÂU HỎI (FOOTER) --- */
  .test-footer { height: 50px !important; padding: 5px !important; }
  .q-nav-btn { min-width: 35px !important; height: 35px !important; font-size: 0.9rem !important; }
}

/* =================================================================
   🏆 BẢNG CHI TIẾT KẾT QUẢ SAU KHI NỘP BÀI (FullTestPage)
   ================================================================= */
.detailed-result-container {
  width: 100%;
  max-width: 1000px;
  margin: 30px auto;
  background: white;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  padding: 30px;
  text-align: left;
}

.result-grid {
  display: grid;
  /* Tự động chia cột: Rộng tối thiểu 180px, tối đa auto */
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 15px;
}

.result-item {
  padding: 15px;
  border-radius: 8px;
  border: 1px solid #eee;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: transform 0.2s;
}

.result-item:hover {
  transform: translateY(-2px);
}

.result-item.correct { 
  background-color: #f0fff4; 
  border-color: #c6f6d5; 
}
.result-item.wrong { 
  background-color: #fff5f5; 
  border-color: #fed7d7; 
}

.result-item-header { 
  display: flex; 
  justify-content: space-between; 
  font-weight: 800; 
  color: #555; 
  font-size: 0.95rem;
}

.result-item-ans { 
  font-size: 1.1rem; 
  font-weight: 700; 
  word-break: break-word;
}

.result-correct-ans { 
  font-size: 0.9rem; 
  color: #d32f2f; 
  margin-top: auto; /* Đẩy xuống đáy thẻ */
  border-top: 1px dashed #feb2b2; 
  padding-top: 8px;
}

/* Fix lỗi màn hình Result bị cuộn không được khi quá dài */
.result-screen.scrollable {
  justify-content: flex-start !important; /* Đẩy nội dung lên trên để cuộn */
  overflow-y: auto !important;
  padding: 40px 20px;
}

@media (max-width: 600px) {
  .detailed-result-container { padding: 15px; }
  .result-grid { grid-template-columns: repeat(2, 1fr); /* Mobile chia 2 cột */ }
}
