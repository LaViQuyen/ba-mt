   (Thêm vào cuối file App.css)
   ================================================================= */
.confirm-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 10000;
  display: flex; align-items: center; justify-content: center;
  backdrop-filter: blur(3px);
}

.confirm-box {
  background: white; padding: 30px; border-radius: 12px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  width: 400px; text-align: center;
  animation: popIn 0.3s ease-out;
}

.confirm-title {
  font-size: 1.4rem; color: #002554; margin: 0 0 15px 0; font-weight: 800;
}

.confirm-desc {
  color: #555; margin-bottom: 25px; line-height: 1.5; font-size: 1rem;
}

.confirm-actions { display: flex; gap: 15px; justify-content: center; }

.btn-cancel {
  padding: 10px 25px; border: 1px solid #ccc; background: white;
  color: #555; border-radius: 6px; font-weight: 700; cursor: pointer; transition: 0.2s;
}
.btn-cancel:hover { background: #f1f1f1; }

.btn-confirm {
  padding: 10px 25px; border: none; background: #002554;
  color: white; border-radius: 6px; font-weight: 700; cursor: pointer; transition: 0.2s;
}
.btn-confirm:hover {
  background: #00193a; transform: translateY(-2px); box-shadow: 0 4px 10px rgba(0,37,84,0.3);
}

@keyframes popIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}


