  min-width: 80px;           /* Chiều rộng tối thiểu */
  max-width: 100px;          /* Không cho quá dài */
}

.gap-input:focus {
  border-bottom: 2px solid #002554;
  background: #e8f0fe;
}

/* Style cho Dropdown Matching */
.gap-select {
  padding: 4px 8px;
  border: 1px solid #002554;
  border-radius: 4px;
  background-color: white;
  color: #002554;
  font-weight: bold;
  font-size: 14px;
  margin-left: 5px;
  cursor: pointer;
  min-width: 60px; /* Đảm bảo đủ rộng để bấm */
