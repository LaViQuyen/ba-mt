                        <textarea className="note-textarea" placeholder="Type your note here..." value={note.content} onKeyDown={(e) => e.stopPropagation()} onChange={(e) => setNotes(prev => ({ ...prev, [id]: { ...prev[id], content: e.target.value } }))} />
