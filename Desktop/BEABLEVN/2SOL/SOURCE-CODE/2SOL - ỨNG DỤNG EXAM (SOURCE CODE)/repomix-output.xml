const { onSchedule } = require("firebase-functions/v2/scheduler");
const admin = require("firebase-admin");

admin.initializeApp();

// ============================================================================
// HÀM TỰ ĐỘNG DỌN RÁC TOÀN NĂNG (CLEANUP ALL OLD DRAFTS)
// Chạy tự động vào lúc 00:00 mỗi ngày để quét sạch bản nháp quá 3 ngày
// ============================================================================
exports.cleanupOldDrafts = onSchedule("every 24 hours", async (event) => {
    const db = admin.database();
    const draftsRef = db.ref('drafts');
    
    const snapshot = await draftsRef.once('value');
    if (!snapshot.exists()) {
        console.log("Không có dữ liệu nháp nào trên hệ thống.");
        return null;
    }

    const now = Date.now();
    const THREE_DAYS_MS = 3 * 24 * 60 * 60 * 1000; // 3 ngày
    const updates = {};
    let deletedCount = 0;

    // Hàm duyệt cây dữ liệu để tìm thuộc tính 'updatedAt'
    const scanAndClean = (snap, path) => {
        const val = snap.val();
        if (!val || typeof val !== 'object') return;

        // Nếu tìm thấy một node chứa dữ liệu nháp có updatedAt
        if (val.updatedAt) {
            const updatedAtMs = new Date(val.updatedAt).getTime();
            if (now - updatedAtMs > THREE_DAYS_MS) {
                updates[path] = null; // Thêm vào danh sách xóa
                deletedCount++;
            }
            return; // Đã xử lý xong node nháp này, không cần đi sâu hơn
        }

        // Nếu chưa gặp node nháp, tiếp tục đi sâu vào các nhánh con
        snap.forEach((childSnap) => {
            scanAndClean(childSnap, `${path}/${childSnap.key}`);
        });
    };

    // Bắt đầu quét từ gốc thư mục 'drafts'
    snapshot.forEach((studentSnap) => {
        const studentId = studentSnap.key;
        scanAndClean(studentSnap, studentId);
    });

    // Tiến hành cập nhật xóa hàng loạt lên Firebase Cloud Database
    if (Object.keys(updates).length > 0) {
        await draftsRef.update(updates);
        console.log(`[Hệ thống] Đã tự động dọn dẹp sạch sẽ ${deletedCount} bản nháp (bao gồm cả Mock Test và Writing Test) quá hạn 3 ngày.`);
    } else {
        console.log("[Hệ thống] Kiểm tra hoàn tất: Không có bản nháp nào bị quá hạn.");
    }
    
    return null;
});
