}

/* =================================================================
   BUTTON LOGOUT (HEADER)
   ================================================================= */
.btn-logout {
  background-color: transparent;
  color: #d32f2f; /* Màu đỏ đô nhẹ nhàng, báo hiệu hành động "Thoát" */
  border: 1px solid #d32f2f;
  padding: 6px 16px;
  border-radius: 50px; /* Bo tròn kiểu viên thuốc (Pill shape) hiện đại */
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px; /* Khoảng cách giữa chữ và icon */
  transition: all 0.2s ease-in-out;
  font-family: 'Segoe UI', sans-serif;
}

/* Hiệu ứng khi di chuột vào */
.btn-logout:hover {
  background-color: #d32f2f;
  color: white;
  transform: translateY(-1px); /* Nổi lên nhẹ */
  box-shadow: 0 2px 5px rgba(211, 47, 47, 0.2);
}

/* Hiệu ứng khi nhấn */
.btn-logout:active {
  transform: translateY(0);
}

/* Responsive trên điện thoại */
@media (max-width: 600px) {
  .btn-logout span {
    display: none; /* Ẩn chữ "Thoát" trên mobile, chỉ hiện icon */
  }
  .btn-logout {
    padding: 8px;
    border-radius: 50%; /* Thành hình tròn */
    width: 36px;
    height: 36px;
    justify-content: center;
  }
  .btn-logout i {
    font-size: 1.1rem;
  }
}

/* 🔥 QUAN TRỌNG: Tự động thu nhỏ ảnh ở trang chủ để không bị vỡ layout */
.app-content img {
  max-height: 50vh; /* Ảnh chỉ được cao tối đa 50% màn hình */
  width: auto;      /* Chiều rộng tự chỉnh theo tỷ lệ */
  object-fit: contain;
}

/* 5. FOOTER (Cố định 40px) */
.main-footer {
  height: 40px;
  background-color: #002554 ; 
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.9rem;
  font-weight: 500;
  flex-shrink: 0; /* Luôn giữ đúng 40px, không bị nội dung đè bẹp */
  z-index: 10000;
}

/* ... (GIỮ NGUYÊN CÁC CLASS KHÁC BÊN DƯỚI NHƯ .nav-center-logo, .nav-right-text...) ... */

/* Class mới: Định vị Logo nằm CHÍNH GIỮA tuyệt đối */
.nav-center-logo {
