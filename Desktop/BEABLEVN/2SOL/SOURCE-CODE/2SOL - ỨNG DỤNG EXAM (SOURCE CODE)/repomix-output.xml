/* --- ĐIỀU CHỈNH QUAN TRỌNG CHO TRANG LÀM BÀI --- */
/* Cũ là 100vh, giờ phải trừ đi 70px của Header để vừa khít màn hình */
.test-container {
  height: calc(100vh - 70px); 
  display: flex; 
  flex-direction: column; 
  background: white;
}

/* Chỉnh lại vị trí của Navbar cũ (nếu còn dùng style cũ thì xóa đi, dùng .main-navbar ở trên) */
.logo { font-size: 22px; font-weight: 800; color: #002554; }

/* Container */
.container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }

/* Chia cột thẻ trang HomePage */
.grid { 
  display: grid; 
  /* 🔥 QUAN TRỌNG: Chia thành 4 cột bằng nhau trên màn hình lớn */
  grid-template-columns: repeat(4, 1fr); 
  gap: 25px; 
}

/* --- THÊM PHẦN RESPONSIVE ĐỂ KHÔNG BỊ LỖI TRÊN ĐIỆN THOẠI/TABLET --- */

/* Màn hình Tablet hoặc Laptop nhỏ (< 1100px): Hiển thị 2 cột */
@media (max-width: 1100px) {
  .grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Màn hình Điện thoại (< 600px): Hiển thị 1 cột dọc */
@media (max-width: 600px) {
  .grid {
    grid-template-columns: 1fr;
  }
}
/*  */
.card {
  background: white; border-radius: 12px; padding: 25px;
  box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  transition: transform 0.2s;
}
.card:hover { transform: translateY(-5px); box-shadow: 0 10px 15px rgba(0,0,0,0.1); }
.card h3 { margin-top: 10px; color: #002554; }
.btn-start {
  display: block; width: 100%; padding: 12px 0; margin-top: 20px;
  background: #002554; color: white; text-align: center; border-radius: 6px; font-weight: 600;
  border: none; cursor: pointer;
}
.btn-start:hover { background: #01377e; }

/* Gap Input Style (Cho bài điền từ sau này) */
.gap-input { border: none; border-bottom: 1px solid #333; background: #f9f9f9; text-align: center; width: 100px; margin: 0 5px; color: #002554; font-weight: bold; }
.gap-input:focus { outline: none; border-bottom: 2px solid #002554; background: #e3f2fd; }
.badge { background: #002554; color: white; font-size: 11px; padding: 2px 6px; border-radius: 4px; margin-right: 5px; }

/* --- QUESTION PALETTE (PHIÊN BẢN CHÂN TRANG) --- */

/* 1. Điều chỉnh khung bao quanh để chừa chỗ cho footer */
.test-layout-wrapper {
  display: block; /* Bỏ flex chia cột */
  height: calc(100vh - 130px); /* Trừ đi chiều cao Header + Footer */
  overflow: hidden; 
  position: relative;
}

.main-test-area {
  height: 100%;
  overflow: hidden;
}

/* --- QUESTION PALETTE (PHIÊN BẢN COMPACT CHO PC/LAPTOP) --- */

/* Thanh footer cố định */
.bottom-palette-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 50px; /* Giảm chiều cao từ 70px -> 50px */
  background: #fff;
  border-top: 1px solid #ccc; /* Viền mỏng hơn */
  display: flex;
  align-items: center;
  padding: 0 15px;
  gap: 6px; /* Giảm khoảng cách giữa các ô */
  overflow-x: auto;
  white-space: nowrap;
  z-index: 9999;
  box-shadow: 0 -2px 5px rgba(0,0,0,0.05);
}

/* Tùy chỉnh thanh cuộn cho đẹp và mảnh hơn */
.bottom-palette-bar::-webkit-scrollbar {
  height: 4px; /* Thanh cuộn siêu mỏng */
}
.bottom-palette-bar::-webkit-scrollbar-thumb {
  background: #002554;
  border-radius: 2px;
}

/* Các ô tròn số câu hỏi */
.q-circle {
  flex-shrink: 0;
  width: 32px;  /* Giảm size từ 40px -> 32px */
  height: 32px;
  border: 1px solid #ccc;
  border-radius: 50%; /* Đổi thành hình vuông bo góc nhẹ cho hiện đại hơn, hoặc để 50% nếu thích tròn */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px; /* Chữ nhỏ lại */
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  background: #f9f9f9;
  color: #333;
}

.q-circle:hover { background: #e3f2fd; border-color: #002554; }
.q-circle.filled { background: #002554; color: white; border-color: #002554; } 
.q-circle.correct { background: #2e7d32; color: white; border-color: #2e7d32; }
.q-circle.wrong { background: #d32f2f; color: white; border-color: #d32f2f; }

/* Label chữ QUESTIONS */
.palette-label {
    font-size: 12px; 
    font-weight: bold; 
    color: #002554; 
    margin-right: 10px;
}

/* --- TỐI ƯU Ô NHẬP LIỆU TRONG BẢNG --- */
.gap-input {
  display: inline-block;     /* Bắt buộc để nằm cùng dòng */
  border: none;
  border-bottom: 1px solid #333;
  background: #f9f9f9;
  text-align: center;
  color: #002554;
  font-weight: bold;
  font-size: 14px;
  padding: 0 5px;
  margin: 0 5px;
  outline: none;
  transition: all 0.2s;
  
  /* QUAN TRỌNG: Độ rộng linh hoạt */
