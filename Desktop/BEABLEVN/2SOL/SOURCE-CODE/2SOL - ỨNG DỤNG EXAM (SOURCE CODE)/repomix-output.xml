  cursor: pointer;
  margin-top: 10px;
}
.btn-submit-login:hover { background: #01377e; }

.close-modal {
  position: absolute;
  top: 10px; right: 15px;
  background: none; border: none;
  font-size: 20px; cursor: pointer; color: #999;
}
.close-modal:hover { color: #333; }

